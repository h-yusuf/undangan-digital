---
interface Props {
  date: string;
  time: string;
  location?: string;
}

const { date, time, location } = Astro.props;
---

<section class="py-20 bg-white">
  <div class="container-custom">
    <div class="max-w-3xl mx-auto text-center">
      <h2 class="text-4xl font-bold font-serif text-gray-900 mb-8">
        Detail Acara
      </h2>
      
      <div class="grid md:grid-cols-2 gap-8 mb-12">
        <div class="bg-primary-50 p-8 rounded-2xl">
          <div class="text-5xl mb-4">📅</div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">Tanggal</h3>
          <p class="text-gray-700">{date}</p>
        </div>
        
        <div class="bg-primary-50 p-8 rounded-2xl">
          <div class="text-5xl mb-4">🕐</div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">Waktu</h3>
          <p class="text-gray-700">{time} WIB</p>
        </div>
      </div>
      
      {location && (
        <div class="bg-primary-50 p-8 rounded-2xl">
          <div class="text-5xl mb-4">📍</div>
          <h3 class="text-xl font-semibold text-gray-900 mb-2">Lokasi</h3>
          <p class="text-gray-700">{location}</p>
        </div>
      )}
    </div>
  </div>
</section>
