---
interface Props {
  eventId: string;
  guestId?: string;
}

const { eventId, guestId } = Astro.props;
---

<section class="py-20 bg-gradient-to-br from-primary-50 to-primary-100">
  <div class="container-custom">
    <div class="max-w-2xl mx-auto text-center">
      <h2 class="text-4xl font-bold font-serif text-gray-900 mb-4">
        Konfirmasi Kehadiran
      </h2>
      <p class="text-gray-600 mb-8">
        Mohon konfirmasi kehadiran Anda
      </p>
      
      <div class="bg-white p-8 rounded-2xl shadow-lg">
        {guestId ? (
          <div id="rsvp-form" data-guest-id={guestId}>
            <div class="mb-6">
              <label class="block text-left text-gray-700 font-medium mb-2">
                Status Kehadiran
              </label>
              <div class="flex gap-4 justify-center">
                <button 
                  class="rsvp-btn btn-primary flex-1"
                  data-status="hadir"
                >
                  ✓ Hadir
                </button>
                <button 
                  class="rsvp-btn bg-gray-200 hover:bg-gray-300 text-gray-800 font-medium py-2 px-4 rounded-lg transition-colors flex-1"
                  data-status="tidak_hadir"
                >
                  ✗ Tidak Hadir
                </button>
              </div>
            </div>
            
            <div class="mb-6">
              <label class="block text-left text-gray-700 font-medium mb-2">
                Pesan (Opsional)
              </label>
              <textarea 
                id="rsvp-message"
                class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-primary-500"
                rows="3"
                placeholder="Tulis pesan Anda..."
              ></textarea>
            </div>
            
            <button 
              id="submit-rsvp"
              class="btn-primary w-full"
            >
              Kirim Konfirmasi
            </button>
            
            <div id="rsvp-result" class="mt-4 hidden"></div>
          </div>
        ) : (
          <p class="text-gray-600">
            Silakan buka undangan melalui link personal Anda untuk melakukan konfirmasi kehadiran.
          </p>
        )}
      </div>
    </div>
  </div>
</section>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('rsvp-form');
    if (!form) return;
    
    const guestId = form.dataset.guestId;
    let selectedStatus = '';
    
    const buttons = document.querySelectorAll('.rsvp-btn');
    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        buttons.forEach(b => {
          b.classList.remove('btn-primary');
          b.classList.add('bg-gray-200', 'hover:bg-gray-300', 'text-gray-800');
        });
        
        btn.classList.remove('bg-gray-200', 'hover:bg-gray-300', 'text-gray-800');
        btn.classList.add('btn-primary');
        
        selectedStatus = btn.dataset.status || '';
      });
    });
    
    const submitBtn = document.getElementById('submit-rsvp');
    const messageInput = document.getElementById('rsvp-message') as HTMLTextAreaElement;
    const resultDiv = document.getElementById('rsvp-result');
    
    submitBtn?.addEventListener('click', async () => {
      if (!selectedStatus) {
        alert('Silakan pilih status kehadiran');
        return;
      }
      
      const apiUrl = import.meta.env.PUBLIC_API_URL || 'http://localhost:8787';
      
      try {
        submitBtn.textContent = 'Mengirim...';
        submitBtn.setAttribute('disabled', 'true');
        
        const response = await fetch(`${apiUrl}/rsvp`, {
          method: 'POST',
          headers: {
            'Content-Type': 'application/json',
          },
          body: JSON.stringify({
            guest_id: guestId,
            status: selectedStatus,
            message: messageInput?.value || '',
          }),
        });
        
        const result = await response.json();
        
        if (resultDiv) {
          resultDiv.classList.remove('hidden');
          if (result.success) {
            resultDiv.className = 'mt-4 p-4 bg-green-100 text-green-800 rounded-lg';
            resultDiv.textContent = '✓ Konfirmasi berhasil dikirim!';
          } else {
            resultDiv.className = 'mt-4 p-4 bg-red-100 text-red-800 rounded-lg';
            resultDiv.textContent = '✗ Gagal mengirim konfirmasi. Silakan coba lagi.';
          }
        }
      } catch (error) {
        if (resultDiv) {
          resultDiv.classList.remove('hidden');
          resultDiv.className = 'mt-4 p-4 bg-red-100 text-red-800 rounded-lg';
          resultDiv.textContent = '✗ Terjadi kesalahan. Silakan coba lagi.';
        }
      } finally {
        submitBtn.textContent = 'Kirim Konfirmasi';
        submitBtn.removeAttribute('disabled');
      }
    });
  });
</script>
