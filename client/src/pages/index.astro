---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Undangan Digital Platform">
  <main class="min-h-screen flex items-center justify-center bg-gradient-to-br from-primary-50 to-primary-100">
    <div class="container-custom text-center">
      <h1 class="text-5xl font-bold font-serif text-primary-900 mb-4">
        Undangan Digital Platform
      </h1>
      <p class="text-xl text-gray-600 mb-8">
        Platform undangan digital modern & elegan
      </p>
      <div class="flex gap-4 justify-center">
        <a href="#" class="btn-primary">
          Mulai Sekarang
        </a>
        <a href="#" class="btn-secondary">
          Lihat Demo
        </a>
      </div>
    </div>
  </main>
</BaseLayout>
