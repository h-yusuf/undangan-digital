          <div class="w-20 h-px bg-gradient-to-r from-transparent to-primary/40"></div>
          <div class="w-2 h-2 bg-primary rounded-full"></div>
          <div class="w-20 h-px bg-gradient-to-l from-transparent to-primary/40"></div>
