---
import BaseLayout from '../layouts/BaseLayout.astro';
import dummyData from '../data/dummy-event.json';
import Button from '../components/ui/Button.astro';
import Card from '../components/ui/Card.astro';
import CardHeader from '../components/ui/CardHeader.astro';
import CardTitle from '../components/ui/CardTitle.astro';
import CardContent from '../components/ui/CardContent.astro';
import Input from '../components/ui/Input.astro';
import Badge from '../components/ui/Badge.astro';
import { Home, Users, Calendar, MapPin, Image, Gift, MessageCircle, Music, Play, Pause } from 'lucide-astro';

const { event } = dummyData;
const guestName = Astro.url.searchParams.get('to') || 'Tamu Undangan';

// Customizable background - bisa diubah via theme config
const bgType = event.theme?.background_type || 'gradient'; // gradient, solid, image
const bgValue = event.theme?.background_value || 'linear-gradient(135deg, #667eea 0%, #764ba2 100%)';

const eventDate = new Date(event.cover.date);
const formattedDate = eventDate.toLocaleDateString('id-ID', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={event.title}>

  <!-- Customizable Background -->
  <div 
    class="fixed inset-0 -z-10"
    style={bgType === 'gradient' 
      ? `background: ${bgValue}` 
      : bgType === 'image' 
      ? `background-image: url(${bgValue}); background-size: cover; background-position: center;`
      : `background-color: ${bgValue}`
    }
  >
    <div class="absolute inset-0 bg-black/10"></div>
  </div>

  <!-- Music Player -->
  <div id="music-player" class="fixed top-8 right-8 z-50">
    <button 
      id="music-toggle" 
      class="group relative w-14 h-14 bg-white/80 backdrop-blur-md rounded-full shadow-xl hover:shadow-2xl transition-all duration-300 hover:scale-110 border border-white/20"
    >
      <Play id="music-icon-play" class="w-6 h-6 text-primary absolute inset-0 m-auto hidden" />
      <Pause id="music-icon-pause" class="w-6 h-6 text-primary absolute inset-0 m-auto" />
      <div class="absolute inset-0 bg-gradient-to-r from-primary/20 to-primary/10 rounded-full opacity-0 group-hover:opacity-100 transition-opacity"></div>
    </button>
    <audio id="background-music" loop>
      <source src={event.music.url} type="audio/mpeg">
    </audio>
  </div>

  <!-- Bottom Navigation -->
  <nav class="fixed bottom-0 left-0 right-0 z-50">
    <div class="bg-gradient-to-t from-black/40 via-black/20 to-transparent backdrop-blur-xl">
      <div class="container mx-auto">
        <div class="flex justify-around items-center h-20 md:h-24 max-w-6xl mx-auto px-2 md:px-6">
          <a href="#hero" class="nav-link group flex flex-col items-center gap-1.5 md:gap-3 text-foreground/80 hover:text-foreground transition-all duration-300 relative">
            <div class="relative">
              <div class="absolute inset-0 bg-primary/20 rounded-xl md:rounded-2xl blur-lg group-hover:blur-xl transition-all duration-300 opacity-0 group-hover:opacity-100"></div>
              <div class="relative w-10 h-10 md:w-12 md:h-12 bg-primary/10 backdrop-blur-sm rounded-xl md:rounded-2xl flex items-center justify-center border border-primary/20 group-hover:bg-primary/20 transition-all duration-300">
                <Home class="w-5 h-5 md:w-6 md:h-6 text-primary" />
              </div>
            </div>
            <span class="text-[10px] md:text-xs font-medium tracking-wide">Beranda</span>
          </a>
          
          <a href="#couple" class="nav-link group flex flex-col items-center gap-1.5 md:gap-3 text-foreground/80 hover:text-foreground transition-all duration-300 relative">
            <div class="relative">
              <div class="absolute inset-0 bg-primary/20 rounded-xl md:rounded-2xl blur-lg group-hover:blur-xl transition-all duration-300 opacity-0 group-hover:opacity-100"></div>
              <div class="relative w-10 h-10 md:w-12 md:h-12 bg-primary/10 backdrop-blur-sm rounded-xl md:rounded-2xl flex items-center justify-center border border-primary/20 group-hover:bg-primary/20 transition-all duration-300">
                <Users class="w-5 h-5 md:w-6 md:h-6 text-primary" />
              </div>
            </div>
            <span class="text-[10px] md:text-xs font-medium tracking-wide">Mempelai</span>
          </a>
          
          <a href="#event" class="nav-link group flex flex-col items-center gap-1.5 md:gap-3 text-foreground/80 hover:text-foreground transition-all duration-300 relative">
            <div class="relative">
              <div class="absolute inset-0 bg-primary/20 rounded-xl md:rounded-2xl blur-lg group-hover:blur-xl transition-all duration-300 opacity-0 group-hover:opacity-100"></div>
              <div class="relative w-10 h-10 md:w-12 md:h-12 bg-primary/10 backdrop-blur-sm rounded-xl md:rounded-2xl flex items-center justify-center border border-primary/20 group-hover:bg-primary/20 transition-all duration-300">
                <Calendar class="w-5 h-5 md:w-6 md:h-6 text-primary" />
              </div>
            </div>
            <span class="text-[10px] md:text-xs font-medium tracking-wide">Acara</span>
          </a>
          
          <a href="#maps" class="nav-link group flex flex-col items-center gap-1.5 md:gap-3 text-foreground/80 hover:text-foreground transition-all duration-300 relative">
            <div class="relative">
              <div class="absolute inset-0 bg-primary/20 rounded-xl md:rounded-2xl blur-lg group-hover:blur-xl transition-all duration-300 opacity-0 group-hover:opacity-100"></div>
              <div class="relative w-10 h-10 md:w-12 md:h-12 bg-primary/10 backdrop-blur-sm rounded-xl md:rounded-2xl flex items-center justify-center border border-primary/20 group-hover:bg-primary/20 transition-all duration-300">
                <MapPin class="w-5 h-5 md:w-6 md:h-6 text-primary" />
              </div>
            </div>
            <span class="text-[10px] md:text-xs font-medium tracking-wide">Lokasi</span>
          </a>
          
          <a href="#gallery" class="nav-link group flex flex-col items-center gap-1.5 md:gap-3 text-foreground/80 hover:text-foreground transition-all duration-300 relative">
            <div class="relative">
              <div class="absolute inset-0 bg-primary/20 rounded-xl md:rounded-2xl blur-lg group-hover:blur-xl transition-all duration-300 opacity-0 group-hover:opacity-100"></div>
              <div class="relative w-10 h-10 md:w-12 md:h-12 bg-primary/10 backdrop-blur-sm rounded-xl md:rounded-2xl flex items-center justify-center border border-primary/20 group-hover:bg-primary/20 transition-all duration-300">
                <Image class="w-5 h-5 md:w-6 md:h-6 text-primary" />
              </div>
            </div>
            <span class="text-[10px] md:text-xs font-medium tracking-wide">Galeri</span>
          </a>
          
          <a href="#gift" class="nav-link group flex flex-col items-center gap-1.5 md:gap-3 text-foreground/80 hover:text-foreground transition-all duration-300 relative">
            <div class="relative">
              <div class="absolute inset-0 bg-primary/20 rounded-xl md:rounded-2xl blur-lg group-hover:blur-xl transition-all duration-300 opacity-0 group-hover:opacity-100"></div>
              <div class="relative w-10 h-10 md:w-12 md:h-12 bg-primary/10 backdrop-blur-sm rounded-xl md:rounded-2xl flex items-center justify-center border border-primary/20 group-hover:bg-primary/20 transition-all duration-300">
                <Gift class="w-5 h-5 md:w-6 md:h-6 text-primary" />
              </div>
            </div>
            <span class="text-[10px] md:text-xs font-medium tracking-wide">Hadiah</span>
          </a>
          
          <a href="#rsvp" class="nav-link group flex flex-col items-center gap-1.5 md:gap-3 text-foreground/80 hover:text-foreground transition-all duration-300 relative">
            <div class="relative">
              <div class="absolute inset-0 bg-primary/20 rounded-xl md:rounded-2xl blur-lg group-hover:blur-xl transition-all duration-300 opacity-0 group-hover:opacity-100"></div>
              <div class="relative w-10 h-10 md:w-12 md:h-12 bg-primary/10 backdrop-blur-sm rounded-xl md:rounded-2xl flex items-center justify-center border border-primary/20 group-hover:bg-primary/20 transition-all duration-300">
                <MessageCircle class="w-5 h-5 md:w-6 md:h-6 text-primary" />
              </div>
            </div>
            <span class="text-[10px] md:text-xs font-medium tracking-wide">RSVP</span>
          </a>
        </div>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <section id="hero" class="min-h-screen flex items-center justify-center px-4 py-20 pb-32 relative">
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-black/20 to-black/40"></div>
    <div class="container max-w-5xl text-center space-y-8 md:space-y-12 animate-fade-in relative z-10">
      <!-- Decorative Element -->
      <div class="animate-on-scroll" data-animation="fade-up">
        <div class="inline-flex items-center gap-2 px-4 md:px-6 py-2 md:py-3 bg-white/10 backdrop-blur-md rounded-full border border-white/20">
          <div class="w-2 h-2 bg-white rounded-full animate-pulse"></div>
          <span class="text-foreground/90 text-xs md:text-sm font-medium">{event.cover.title}</span>
        </div>
      </div>

      <!-- Names -->
      <div class="space-y-3 md:space-y-4 animate-on-scroll" data-animation="zoom-in">
        <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-9xl font-bold text-foreground leading-none font-serif tracking-tight px-2">
          {event.cover.bride}
        </h1>
        <div class="flex items-center justify-center gap-3 md:gap-4">
          <div class="w-12 md:w-20 h-px bg-white/60"></div>
          <span class="text-foreground/80 text-xl md:text-2xl">&</span>
          <div class="w-12 md:w-20 h-px bg-white/60"></div>
        </div>
        <h1 class="text-5xl sm:text-6xl md:text-7xl lg:text-9xl font-bold text-foreground leading-none font-serif tracking-tight px-2">
          {event.cover.groom}
        </h1>
      </div>

      <!-- Date -->
      <div class="animate-on-scroll" data-animation="fade-up">
        <p class="text-base md:text-xl lg:text-2xl text-foreground/90 font-light px-4">
          {formattedDate}
        </p>
      </div>

      <!-- Countdown -->
      <div id="countdown" class="grid grid-cols-4 gap-2 md:gap-4 max-w-lg mx-auto px-4 animate-on-scroll" data-animation="zoom-in">
        <div class="bg-white/10 backdrop-blur-md rounded-xl md:rounded-2xl p-3 md:p-6 border border-white/20">
          <div id="days" class="text-2xl md:text-4xl font-bold text-foreground mb-1 md:mb-2">00</div>
          <div class="text-[10px] md:text-xs text-foreground/70 uppercase tracking-wider">Hari</div>
        </div>
        <div class="bg-white/10 backdrop-blur-md rounded-xl md:rounded-2xl p-3 md:p-6 border border-white/20">
          <div id="hours" class="text-2xl md:text-4xl font-bold text-foreground mb-1 md:mb-2">00</div>
          <div class="text-[10px] md:text-xs text-foreground/70 uppercase tracking-wider">Jam</div>
        </div>
        <div class="bg-white/10 backdrop-blur-md rounded-xl md:rounded-2xl p-3 md:p-6 border border-white/20">
          <div id="minutes" class="text-2xl md:text-4xl font-bold text-foreground mb-1 md:mb-2">00</div>
          <div class="text-[10px] md:text-xs text-foreground/70 uppercase tracking-wider">Menit</div>
        </div>
        <div class="bg-white/10 backdrop-blur-md rounded-xl md:rounded-2xl p-3 md:p-6 border border-white/20">
          <div id="seconds" class="text-2xl md:text-4xl font-bold text-foreground mb-1 md:mb-2">00</div>
          <div class="text-[10px] md:text-xs text-foreground/70 uppercase tracking-wider">Detik</div>
        </div>
      </div>

      <!-- Guest Name Card -->
      <div class="animate-on-scroll px-4" data-animation="fade-up">
        <div class="bg-white/10 backdrop-blur-md rounded-2xl p-6 md:p-8 max-w-md mx-auto border border-white/20">
          <p class="text-foreground/70 text-xs md:text-sm mb-2 md:mb-3">Kepada Yth:</p>
          <p class="text-xl md:text-3xl font-bold text-foreground">{guestName}</p>
        </div>
      </div>

      <!-- CTA Button -->
      <div class="animate-on-scroll px-4" data-animation="fade-up">
        <button class="group relative px-6 md:px-8 py-3 md:py-4 bg-white text-foreground rounded-full font-semibold hover:shadow-2xl transition-all duration-300 hover:scale-105 w-full max-w-xs mx-auto">
          <a href="#couple" class="flex items-center justify-center gap-2 md:gap-3">
            <span class="text-sm md:text-base">Buka Undangan</span>
            <svg class="w-4 h-4 md:w-5 md:h-5 transition-transform group-hover:translate-y-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
            </svg>
          </a>
        </button>
      </div>
    </div>
  </section>

  <!-- Couple Section -->
  <section id="couple" class="py-16 md:py-24 bg-gradient-to-b from-background to-secondary">
    <div class="container px-4">
      <div class="text-center mb-12 md:mb-20 space-y-4 md:space-y-6 animate-on-scroll" data-animation="fade-up">
        <div class="inline-flex items-center gap-2 px-3 md:px-4 py-2 bg-primary/10 rounded-full">
          <svg class="w-3 h-3 md:w-4 md:h-4 text-primary" fill="currentColor" viewBox="0 0 20 20">
            <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"/>
          </svg>
          <span class="text-primary text-xs md:text-sm font-medium">Pasangan Pengantin</span>
        </div>
        <h2 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold font-serif bg-gradient-to-r from-primary to-primary/60 bg-clip-text text-transparent px-4">
          Mempelai
        </h2>
        <p class="text-sm md:text-base text-muted-foreground max-w-2xl mx-auto px-4">Dengan memohon rahmat dan ridho Allah Subhanahu wa Ta'ala, kami merencanakan pernikahan kami:</p>
      </div>

      <div class="grid md:grid-cols-2 gap-12 md:gap-16 max-w-6xl mx-auto mb-12 md:mb-20">
        <!-- Bride -->
        <div class="text-center space-y-4 md:space-y-6 animate-on-scroll" data-animation="fade-right">
          <div class="relative px-4">
            <div class="absolute inset-0 bg-gradient-to-t from-primary/20 to-transparent rounded-3xl blur-xl"></div>
            <div class="relative w-full max-w-sm h-80 sm:h-96 mx-auto rounded-2xl md:rounded-3xl overflow-hidden shadow-2xl border-2 md:border-4 border-white/20 bg-white/10 backdrop-blur-sm">
              <img src={event.couple.bride.photo_url} alt={event.couple.bride.full_name} class="w-full h-full object-cover">
            </div>
            <div class="absolute -bottom-3 md:-bottom-4 left-1/2 transform -translate-x-1/2 px-4 md:px-6 py-2 md:py-3 bg-white rounded-full shadow-lg">
              <span class="text-primary font-bold text-xs md:text-base">Mempelai Wanita</span>
            </div>
          </div>
          <div class="space-y-3 md:space-y-4 px-4 pt-4">
            <h3 class="text-2xl md:text-3xl font-bold font-serif">{event.couple.bride.full_name}</h3>
            <p class="text-sm md:text-base text-muted-foreground leading-relaxed">{event.couple.bride.parents}</p>
            <a href={`https://instagram.com/${event.couple.bride.instagram.replace('@', '')}`} target="_blank" class="inline-flex items-center gap-2 px-5 md:px-6 py-2.5 md:py-3 bg-gradient-to-r from-primary to-primary/60 text-white rounded-full hover:shadow-lg transition-all duration-300 hover:scale-105 text-sm md:text-base">
              <svg class="w-4 h-4 md:w-5 md:h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
              <span>{event.couple.bride.instagram}</span>
            </a>
          </div>
        </div>

        <!-- Groom -->
        <div class="text-center space-y-4 md:space-y-6 animate-on-scroll" data-animation="fade-left">
          <div class="relative px-4">
            <div class="absolute inset-0 bg-gradient-to-t from-primary/20 to-transparent rounded-3xl blur-xl"></div>
            <div class="relative w-full max-w-sm h-80 sm:h-96 mx-auto rounded-2xl md:rounded-3xl overflow-hidden shadow-2xl border-2 md:border-4 border-white/20 bg-white/10 backdrop-blur-sm">
              <img src={event.couple.groom.photo_url} alt={event.couple.groom.full_name} class="w-full h-full object-cover">
            </div>
            <div class="absolute -bottom-3 md:-bottom-4 left-1/2 transform -translate-x-1/2 px-4 md:px-6 py-2 md:py-3 bg-white rounded-full shadow-lg">
              <span class="text-primary font-bold text-xs md:text-base">Mempelai Pria</span>
            </div>
          </div>
          <div class="space-y-3 md:space-y-4 px-4 pt-4">
            <h3 class="text-2xl md:text-3xl font-bold font-serif">{event.couple.groom.full_name}</h3>
            <p class="text-sm md:text-base text-muted-foreground leading-relaxed">{event.couple.groom.parents}</p>
            <a href={`https://instagram.com/${event.couple.groom.instagram.replace('@', '')}`} target="_blank" class="inline-flex items-center gap-2 px-5 md:px-6 py-2.5 md:py-3 bg-gradient-to-r from-primary to-primary/60 text-white rounded-full hover:shadow-lg transition-all duration-300 hover:scale-105 text-sm md:text-base">
              <svg class="w-4 h-4 md:w-5 md:h-5" fill="currentColor" viewBox="0 0 24 24">
                <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
              </svg>
              <span>{event.couple.groom.instagram}</span>
            </a>
          </div>
        </div>
      </div>

      <!-- Love Story -->
      <div class="max-w-4xl mx-auto animate-on-scroll px-4" data-animation="zoom-in">
        <div class="bg-gradient-to-r from-primary/10 to-primary/5 rounded-2xl md:rounded-3xl p-6 md:p-12 backdrop-blur-sm border border-primary/20">
          <div class="text-center space-y-4 md:space-y-6">
            <div class="inline-flex items-center justify-center w-12 h-12 md:w-16 md:h-16 bg-gradient-to-br from-primary to-primary/60 rounded-xl md:rounded-2xl">
              <svg class="w-6 h-6 md:w-8 md:h-8 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"/>
              </svg>
            </div>
            <h3 class="text-2xl md:text-3xl font-bold font-serif">Kisah Cinta Kami</h3>
            <p class="text-sm md:text-base lg:text-lg text-muted-foreground leading-relaxed">{event.couple.story}</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Event Details Section -->
  <section id="event" class="py-16 md:py-24 bg-gradient-to-b from-secondary to-background">
    <div class="container px-4">
      <div class="text-center mb-12 md:mb-20 space-y-4 md:space-y-6 animate-on-scroll" data-animation="fade-up">
        <div class="inline-flex items-center gap-2 px-3 md:px-4 py-2 bg-primary/10 rounded-full">
          <Calendar class="w-3 h-3 md:w-4 md:h-4 text-primary" />
          <span class="text-primary text-xs md:text-sm font-medium">Detail Acara</span>
        </div>
        <h2 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold font-serif bg-gradient-to-r from-primary to-primary/60 bg-clip-text text-transparent px-4">
          Waktu & Tempat
        </h2>
        <p class="text-sm md:text-base text-muted-foreground max-w-2xl mx-auto px-4">Dengan memohon rahmat Allah Yang Maha Kuasa, kami bermaksud menyelenggarakan acara pernikahan kami:</p>
      </div>

      <div class="grid md:grid-cols-2 gap-8 md:gap-12 max-w-6xl mx-auto">
        {event.events.map((evt, idx) => (
          <div class="animate-on-scroll" data-animation={idx === 0 ? "fade-right" : "fade-left"}>
            <div class="group relative">
              <!-- Background Gradient -->
              <div class="absolute inset-0 bg-gradient-to-br from-primary/10 to-primary/5 rounded-2xl md:rounded-3xl blur-xl group-hover:blur-2xl transition-all duration-500"></div>
              
              <!-- Card Content -->
              <div class="relative bg-white/80 backdrop-blur-sm rounded-2xl md:rounded-3xl p-6 md:p-8 border border-primary/20 hover:border-primary/40 transition-all duration-300 hover:shadow-2xl">
                <!-- Icon -->
                <div class="flex justify-center mb-4 md:mb-6">
                  <div class="w-16 h-16 md:w-20 md:h-20 bg-gradient-to-br from-primary to-primary/60 rounded-xl md:rounded-2xl flex items-center justify-center shadow-lg">
                    <Calendar class="w-8 h-8 md:w-10 md:h-10 text-white" />
                  </div>
                </div>
                
                <!-- Event Type -->
                <h3 class="text-2xl md:text-3xl font-bold font-serif text-center mb-6 md:mb-8 bg-gradient-to-r from-primary to-primary/60 bg-clip-text text-transparent">
                  {evt.type}
                </h3>
                
                <!-- Event Details -->
                <div class="space-y-4 md:space-y-6">
                  <!-- Date -->
                  <div class="flex items-center gap-3 md:gap-4 p-3 md:p-4 bg-primary/5 rounded-xl md:rounded-2xl">
                    <div class="w-10 h-10 md:w-12 md:h-12 bg-primary/20 rounded-lg md:rounded-xl flex items-center justify-center flex-shrink-0">
                      <Calendar class="w-5 h-5 md:w-6 md:h-6 text-primary" />
                    </div>
                    <div class="min-w-0">
                      <p class="text-xs md:text-sm text-muted-foreground">Tanggal</p>
                      <p class="font-semibold text-sm md:text-base">{evt.date}</p>
                    </div>
                  </div>
                  
                  <!-- Time -->
                  <div class="flex items-center gap-3 md:gap-4 p-3 md:p-4 bg-primary/5 rounded-xl md:rounded-2xl">
                    <div class="w-10 h-10 md:w-12 md:h-12 bg-primary/20 rounded-lg md:rounded-xl flex items-center justify-center flex-shrink-0">
                      <svg class="w-5 h-5 md:w-6 md:h-6 text-primary" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                      </svg>
                    </div>
                    <div class="min-w-0">
                      <p class="text-xs md:text-sm text-muted-foreground">Waktu</p>
                      <p class="font-semibold text-sm md:text-base">{evt.time}</p>
                    </div>
                  </div>
                  
                  <!-- Location -->
                  <div class="flex items-center gap-3 md:gap-4 p-3 md:p-4 bg-primary/5 rounded-xl md:rounded-2xl">
                    <div class="w-10 h-10 md:w-12 md:h-12 bg-primary/20 rounded-lg md:rounded-xl flex items-center justify-center flex-shrink-0">
                      <MapPin class="w-5 h-5 md:w-6 md:h-6 text-primary" />
                    </div>
                    <div class="min-w-0">
                      <p class="text-xs md:text-sm text-muted-foreground">Lokasi</p>
                      <p class="font-semibold text-sm md:text-base">{evt.location}</p>
                      <p class="text-xs md:text-sm text-muted-foreground mt-1 break-words">{evt.address}</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Maps Section -->
  <section id="maps" class="py-16 md:py-24 bg-gradient-to-b from-background to-secondary">
    <div class="container px-4">
      <div class="text-center mb-12 md:mb-20 space-y-4 md:space-y-6 animate-on-scroll" data-animation="fade-up">
        <div class="inline-flex items-center gap-2 px-3 md:px-4 py-2 bg-primary/10 rounded-full">
          <MapPin class="w-3 h-3 md:w-4 md:h-4 text-primary" />
          <span class="text-primary text-xs md:text-sm font-medium">Lokasi Acara</span>
        </div>
        <h2 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold font-serif bg-gradient-to-r from-primary to-primary/60 bg-clip-text text-transparent px-4">
          Peta Lokasi
        </h2>
        <p class="text-sm md:text-base text-muted-foreground max-w-2xl mx-auto px-4">{event.location.address}</p>
      </div>

      <div class="grid md:grid-cols-3 gap-6 md:gap-8 max-w-7xl mx-auto px-4">
        <!-- Maps Card -->
        <div class="md:col-span-2 animate-on-scroll" data-animation="fade-right">
          <div class="group relative">
            <!-- Background Gradient -->
            <div class="absolute inset-0 bg-gradient-to-br from-primary/10 to-primary/5 rounded-2xl md:rounded-3xl blur-xl group-hover:blur-2xl transition-all duration-500"></div>
            
            <!-- Card Content -->
            <div class="relative bg-white/90 backdrop-blur-md rounded-2xl md:rounded-3xl overflow-hidden border border-primary/20 hover:border-primary/40 transition-all duration-300 shadow-lg hover:shadow-2xl">
              <!-- Maps Header -->
              <div class="bg-gradient-to-r from-primary/10 to-primary/5 px-6 md:px-8 py-4 md:py-6 border-b border-primary/10">
                <div class="flex items-center justify-between">
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 bg-gradient-to-br from-primary to-primary/60 rounded-xl flex items-center justify-center">
                      <MapPin class="w-5 h-5 text-white" />
                    </div>
                    <div>
                      <p class="text-xs md:text-sm text-primary font-medium">Lokasi Acara</p>
                      <h3 class="text-lg md:text-xl font-bold font-serif text-foreground">{event.location.name}</h3>
                    </div>
                  </div>
                </div>
              </div>
              
              <!-- Maps Container -->
              <div class="relative w-full h-64 md:h-80 overflow-hidden">
                <iframe 
                  src={event.location.maps_embed}
                  width="100%"
                  height="100%"
                  style="border:0; position: absolute; top: 0; left: 0;"
                  allowfullscreen=""
                  loading="lazy"
                  referrerpolicy="no-referrer-when-downgrade"
                ></iframe>
                <div class="absolute inset-0 bg-gradient-to-t from-black/20 to-transparent pointer-events-none"></div>
              </div>
              
              <!-- Maps Footer -->
              <div class="px-6 md:px-8 py-4 md:py-6 space-y-4 bg-white/50 backdrop-blur-sm">
                <div>
                  <p class="text-xs md:text-sm text-muted-foreground mb-2">Alamat Lengkap</p>
                  <p class="text-sm md:text-base font-medium text-foreground leading-relaxed">{event.location.address}</p>
                </div>
                <button class="w-full px-6 py-3 bg-gradient-to-r from-primary to-primary/60 text-white rounded-full hover:shadow-lg transition-all duration-300 hover:scale-105 font-semibold flex items-center justify-center gap-2">
                  <a href={event.location.maps_url} target="_blank" class="flex items-center gap-2">
                    <MapPin class="w-5 h-5" />
                    <span>Buka di Google Maps</span>
                  </a>
                </button>
              </div>
            </div>
          </div>
        </div>

        <!-- QR Code Card -->
        <div class="animate-on-scroll" data-animation="fade-left">
          <div class="group relative h-full">
            <!-- Background Gradient -->
            <div class="absolute inset-0 bg-gradient-to-br from-primary/10 to-primary/5 rounded-3xl blur-xl group-hover:blur-2xl transition-all duration-500"></div>
            
            <!-- Card Content -->
            <div class="relative bg-white/80 backdrop-blur-sm rounded-3xl p-8 border border-primary/20 hover:border-primary/40 transition-all duration-300 h-full flex flex-col justify-center">
              <div class="text-center space-y-6">
                <!-- Icon -->
                <div class="w-16 h-16 bg-gradient-to-br from-primary to-primary/60 rounded-2xl flex items-center justify-center mx-auto">
                  <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v1m6 11h2m-6 0h-2v4m0-11v3m0 0h.01M12 12h4.01M16 20h4M4 12h4m12 0h.01M5 8h2a1 1 0 001-1V5a1 1 0 00-1-1H5a1 1 0 00-1 1v2a1 1 0 001 1zm12 0h2a1 1 0 001-1V5a1 1 0 00-1-1h-2a1 1 0 00-1 1v2a1 1 0 001 1z"/>
                  </svg>
                </div>
                
                <div>
                  <h3 class="text-xl font-bold font-serif mb-2">QR Code Lokasi</h3>
                  <p class="text-sm text-muted-foreground mb-6">Scan dengan smartphone untuk membuka peta</p>
                </div>
                
                <!-- QR Code -->
                <div class="bg-white p-6 rounded-2xl shadow-lg inline-block">
                  <img 
                    src={`https://api.qrserver.com/v1/create-qr-code/?size=200x200&data=${encodeURIComponent(event.location.maps_url)}`} 
                    alt="Location QR Code" 
                    class="w-48 h-48"
                  />
                </div>
                
                <p class="text-xs text-muted-foreground">Arahkan kamera ke QR code</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Gallery Section -->
  <section id="gallery" class="py-24 bg-gradient-to-b from-secondary to-background">
    <div class="container px-4">
      <div class="text-center mb-20 space-y-6 animate-on-scroll" data-animation="fade-up">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-primary/10 rounded-full">
          <Image class="w-4 h-4 text-primary" />
          <span class="text-primary text-sm font-medium">Galeri Foto</span>
        </div>
        <h2 class="text-5xl md:text-7xl font-bold font-serif bg-gradient-to-r from-primary to-primary/60 bg-clip-text text-transparent">
          Kenangan Indah
        </h2>
        <p class="text-muted-foreground max-w-2xl mx-auto">Beberapa momen indah dalam perjalanan cinta kami</p>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-6 max-w-7xl mx-auto">
        {event.gallery.map((photo, idx) => (
          <div class="group animate-on-scroll" data-animation="zoom-in" style={`animation-delay: ${idx * 100}ms`}>
            <div class="relative overflow-hidden rounded-3xl shadow-lg hover:shadow-2xl transition-all duration-500 hover:scale-105">
              <img 
                src={photo.url} 
                alt={photo.caption}
                class="w-full h-80 object-cover transition-transform duration-700 group-hover:scale-110"
                loading="lazy"
              />
              <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500">
                <div class="absolute bottom-0 left-0 right-0 p-6 transform translate-y-full group-hover:translate-y-0 transition-transform duration-500">
                  <p class="text-white font-medium text-lg leading-relaxed">{photo.caption}</p>
                </div>
              </div>
              <!-- Decorative border on hover -->
              <div class="absolute inset-0 border-2 border-white/20 rounded-3xl opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- RSVP Section -->
  <section id="rsvp" class="py-24 bg-gradient-to-b from-background to-secondary">
    <div class="container px-4">
      <div class="text-center mb-20 space-y-6 animate-on-scroll" data-animation="fade-up">
        <div class="inline-flex items-center gap-2 px-4 py-2 bg-primary/10 rounded-full">
          <MessageCircle class="w-4 h-4 text-primary" />
          <span class="text-primary text-sm font-medium">Konfirmasi Kehadiran</span>
        </div>
        <h2 class="text-5xl md:text-7xl font-bold font-serif bg-gradient-to-r from-primary to-primary/60 bg-clip-text text-transparent">
          RSVP
        </h2>
        <p class="text-muted-foreground max-w-2xl mx-auto">Kehadiran Anda adalah kehormatan bagi kami. Mohon konfirmasi kehadiran Anda:</p>
      </div>

      <div class="max-w-3xl mx-auto animate-on-scroll" data-animation="zoom-in">
        <div class="group relative">
          <!-- Background Gradient -->
          <div class="absolute inset-0 bg-gradient-to-br from-primary/10 to-primary/5 rounded-3xl blur-xl group-hover:blur-2xl transition-all duration-500"></div>
          
          <!-- Card Content -->
          <div class="relative bg-white/80 backdrop-blur-sm rounded-3xl p-10 border border-primary/20 hover:border-primary/40 transition-all duration-300">
            <form id="rsvp-form" class="space-y-8">
              <!-- Name Field -->
              <div class="space-y-3">
                <label class="text-lg font-semibold text-foreground">Nama Tamu</label>
                <div class="relative">
                  <Input 
                    type="text" 
                    name="name" 
                    value={guestName}
                    readonly
                    class="text-lg px-6 py-4 bg-primary/5 border-primary/20 rounded-2xl"
                  />
                  <div class="absolute right-4 top-1/2 transform -translate-y-1/2">
                    <svg class="w-5 h-5 text-primary" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd"/>
                    </svg>
                  </div>
                </div>
              </div>

              <!-- Attendance Options -->
              <div class="space-y-4">
                <label class="text-lg font-semibold text-foreground">Konfirmasi Kehadiran</label>
                <div class="grid md:grid-cols-3 gap-4">
                  <label class="cursor-pointer group">
                    <input type="radio" name="status" value="hadir" class="sr-only peer" required />
                    <div class="relative p-6 bg-white border-2 border-border rounded-2xl peer-checked:border-primary peer-checked:bg-primary/5 hover:border-primary/30 transition-all duration-300 group-hover:shadow-lg">
                      <div class="text-center">
                        <div class="w-16 h-16 bg-gradient-to-br from-primary to-primary/60 rounded-2xl flex items-center justify-center mx-auto mb-4 peer-checked:scale-110 transition-transform">
                          <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                          </svg>
                        </div>
                        <h4 class="font-bold text-lg mb-1">Hadir</h4>
                        <p class="text-sm text-muted-foreground">Saya akan datang</p>
                      </div>
                    </div>
                  </label>

                  <label class="cursor-pointer group">
                    <input type="radio" name="status" value="tidak_hadir" class="sr-only peer" />
                    <div class="relative p-6 bg-white border-2 border-border rounded-2xl peer-checked:border-primary peer-checked:bg-primary/5 hover:border-primary/30 transition-all duration-300 group-hover:shadow-lg">
                      <div class="text-center">
                        <div class="w-16 h-16 bg-gradient-to-br from-primary to-primary/60 rounded-2xl flex items-center justify-center mx-auto mb-4 peer-checked:scale-110 transition-transform">
                          <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                          </svg>
                        </div>
                        <h4 class="font-bold text-lg mb-1">Tidak Hadir</h4>
                        <p class="text-sm text-muted-foreground">Maaf tidak bisa</p>
                      </div>
                    </div>
                  </label>

                  <label class="cursor-pointer group">
                    <input type="radio" name="status" value="mungkin" class="sr-only peer" />
                    <div class="relative p-6 bg-white border-2 border-border rounded-2xl peer-checked:border-primary peer-checked:bg-primary/5 hover:border-primary/30 transition-all duration-300 group-hover:shadow-lg">
                      <div class="text-center">
                        <div class="w-16 h-16 bg-gradient-to-br from-primary to-primary/60 rounded-2xl flex items-center justify-center mx-auto mb-4 peer-checked:scale-110 transition-transform">
                          <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 20 20">
                            <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2v-3a1 1 0 00-1-1H9z" clip-rule="evenodd"/>
                          </svg>
                        </div>
                        <h4 class="font-bold text-lg mb-1">Mungkin</h4>
                        <p class="text-sm text-muted-foreground">Masih ragu</p>
                      </div>
                    </div>
                  </label>
                </div>
              </div>

              <!-- Message Field -->
              <div class="space-y-3">
                <label class="text-lg font-semibold text-foreground">Pesan (Opsional)</label>
                <textarea 
                  name="message" 
                  rows="4" 
                  class="w-full px-6 py-4 bg-primary/5 border-primary/20 rounded-2xl resize-none focus:outline-none focus:ring-2 focus:ring-primary transition-all duration-300"
                  placeholder="Tinggalkan pesan untuk mempelai..."
                ></textarea>
              </div>

              <!-- Submit Button -->
              <button type="submit" class="w-full px-8 py-4 bg-gradient-to-r from-primary to-primary/60 text-white rounded-full font-bold text-lg hover:shadow-xl transition-all duration-300 hover:scale-[1.02]">
                Kirim Konfirmasi
              </button>

              <!-- Message Display -->
              <div id="rsvp-message" class="hidden p-6 rounded-2xl"></div>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Gift Section -->
  <section id="gift" class="py-16 md:py-24 bg-gradient-to-b from-secondary to-background">
    <div class="container px-4">
      <div class="text-center mb-12 md:mb-20 space-y-4 md:space-y-6 animate-on-scroll" data-animation="fade-up">
        <div class="inline-flex items-center gap-2 px-3 md:px-4 py-2 bg-primary/10 rounded-full">
          <Gift class="w-3 h-3 md:w-4 md:h-4 text-primary" />
          <span class="text-primary text-xs md:text-sm font-medium">Hadiah Pernikahan</span>
        </div>
        <h2 class="text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-bold font-serif bg-gradient-to-r from-primary to-primary/60 bg-clip-text text-transparent px-4">
          Wedding Gift
        </h2>
        <p class="text-sm md:text-base text-muted-foreground max-w-2xl mx-auto px-4">{event.gift.message}</p>
      </div>

      <div class="max-w-4xl mx-auto animate-on-scroll px-4" data-animation="zoom-in">
        <div class="group relative">
          <!-- Background Gradient -->
          <div class="absolute inset-0 bg-gradient-to-br from-primary/10 to-primary/5 rounded-2xl md:rounded-3xl blur-xl group-hover:blur-2xl transition-all duration-500"></div>
          
          <!-- Card Content -->
          <div class="relative bg-white/90 backdrop-blur-md rounded-2xl md:rounded-3xl p-6 md:p-10 border border-primary/20 hover:border-primary/40 transition-all duration-300 shadow-lg hover:shadow-2xl">
            <!-- Header -->
            <div class="text-center mb-8 md:mb-10">
              <div class="inline-flex items-center justify-center w-16 h-16 md:w-20 md:h-20 bg-gradient-to-br from-primary to-primary/60 rounded-2xl mb-4">
                <Gift class="w-8 h-8 md:w-10 md:h-10 text-white" />
              </div>
              <h3 class="text-xl md:text-2xl font-bold font-serif text-foreground mb-2">Kirim Hadiah</h3>
              <p class="text-sm md:text-base text-muted-foreground">Kehadiran Anda adalah hadiah terindah. Namun jika Anda ingin memberikan hadiah, silakan transfer ke rekening kami:</p>
            </div>
            
            <!-- Bank Accounts -->
            <div class="space-y-4 md:space-y-6">
              {event.gift.accounts.map((account, idx) => (
                <div class="group/bank bg-white/60 backdrop-blur-sm rounded-xl md:rounded-2xl p-4 md:p-6 border border-primary/10 hover:bg-white hover:border-primary/30 transition-all duration-300 hover:shadow-lg">
                  <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 md:gap-6">
                    <!-- Bank Icon -->
                    <div class="w-12 h-12 md:w-16 md:h-16 bg-gradient-to-br from-primary to-primary/60 rounded-xl md:rounded-2xl flex items-center justify-center flex-shrink-0 group-hover/bank:scale-110 transition-transform">
                      <svg class="w-6 h-6 md:w-8 md:h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
                      </svg>
                    </div>
                    
                    <!-- Bank Info -->
                    <div class="flex-1 min-w-0">
                      <div class="flex flex-col sm:flex-row sm:items-center gap-2 mb-2">
                        <h3 class="text-lg md:text-2xl font-bold font-serif text-foreground">{account.bank}</h3>
                        <div class="px-2 md:px-3 py-1 bg-primary/10 rounded-full inline-flex">
                          <span class="text-[10px] md:text-xs font-medium text-primary">Bank Transfer</span>
                        </div>
                      </div>
                      <div class="space-y-1">
                        <p class="font-mono font-bold text-base md:text-xl text-primary">{account.account_number}</p>
                        <p class="text-xs md:text-sm text-muted-foreground">a.n. {account.account_name}</p>
                      </div>
                    </div>
                    
                    <!-- Copy Button -->
                    <button 
                      class="w-full sm:w-auto px-4 md:px-6 py-2.5 md:py-3 bg-gradient-to-r from-primary to-primary/60 text-white rounded-xl md:rounded-2xl hover:shadow-lg transition-all duration-300 hover:scale-105 font-semibold text-sm md:text-base flex items-center justify-center gap-2"
                      onclick={`navigator.clipboard.writeText('${account.account_number}'); this.innerHTML='<svg class=\"w-4 h-4 md:w-5 md:h-5\" fill=\"currentColor\" viewBox=\"0 0 20 20\"><path fill-rule=\"evenodd\" d=\"M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z\" clip-rule=\"evenodd\"/></svg> Tersalin'; setTimeout(() => this.innerHTML='<svg class=\"w-4 h-4 md:w-5 md:h-5\" fill=\"none\" stroke=\"currentColor\" viewBox=\"0 0 24 24\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z\"/></svg> Salin No. Rekening', 2000)`}
                    >
                      <svg class="w-4 h-4 md:w-5 md:h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/>
                      </svg>
                      <span>Salin No. Rekening</span>
                    </button>
                  </div>
                </div>
              ))}
            </div>
            
            <!-- Footer Message -->
            <div class="mt-8 text-center p-4 md:p-6 bg-primary/5 rounded-xl md:rounded-2xl">
              <div class="flex items-center justify-center gap-2 mb-2">
                <svg class="w-4 h-4 text-primary" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"/>
                </svg>
