---
import BaseLayout from '../layouts/BaseLayout.astro';
import dummyData from '../data/dummy-event.json';
import { Home, Users, Calendar, MapPin, Image, Gift, MessageCircle } from 'lucide-astro';

const { event } = dummyData;
const guestName = Astro.url.searchParams.get('to') || 'Tamu Undangan';

const eventDate = new Date(event.cover.date);
const formattedDate = eventDate.toLocaleDateString('id-ID', {
  weekday: 'long',
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<BaseLayout title={event.title}>
  <!-- Music Player -->
  <div id="music-player" class="fixed top-6 right-6 z-50">
    <button 
      id="music-toggle" 
      class="glass-effect hover:scale-110 rounded-full p-4 shadow-2xl transition-all duration-300 group"
      aria-label="Toggle music"
    >
      <svg id="music-icon-play" class="w-5 h-5 hidden text-white" fill="currentColor" viewBox="0 0 20 20">
        <path d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zM7 8a1 1 0 012 0v4a1 1 0 11-2 0V8zm5-1a1 1 0 00-1 1v4a1 1 0 102 0V8a1 1 0 00-1-1z"/>
      </svg>
      <svg id="music-icon-pause" class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
        <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM9.555 7.168A1 1 0 008 8v4a1 1 0 001.555.832l3-2a1 1 0 000-1.664l-3-2z" clip-rule="evenodd"/>
      </svg>
    </button>
    <audio id="background-music" loop>
      <source src={event.music.url} type="audio/mpeg">
    </audio>
  </div>

  <!-- Bottom Icon Navigation Bar -->
  <nav id="bottom-nav" class="fixed bottom-0 left-0 right-0 glass-effect-nav shadow-2xl z-50 border-t border-white/10">
    <div class="container mx-auto px-4">
      <div class="flex justify-around items-center h-20 max-w-3xl mx-auto">
        <a href="#hero" class="nav-icon-link group flex flex-col items-center justify-center text-white/70 hover:text-white transition-all duration-300">
          <div class="p-2 rounded-xl group-hover:bg-white/10 transition-all duration-300">
            <Home class="w-6 h-6" />
          </div>
          <span class="text-xs mt-1 font-medium">Home</span>
        </a>
        <a href="#couple" class="nav-icon-link group flex flex-col items-center justify-center text-white/70 hover:text-white transition-all duration-300">
          <div class="p-2 rounded-xl group-hover:bg-white/10 transition-all duration-300">
            <Users class="w-6 h-6" />
          </div>
          <span class="text-xs mt-1 font-medium">Couple</span>
        </a>
        <a href="#event" class="nav-icon-link group flex flex-col items-center justify-center text-white/70 hover:text-white transition-all duration-300">
          <div class="p-2 rounded-xl group-hover:bg-white/10 transition-all duration-300">
            <Calendar class="w-6 h-6" />
          </div>
          <span class="text-xs mt-1 font-medium">Event</span>
        </a>
        <a href="#maps" class="nav-icon-link group flex flex-col items-center justify-center text-white/70 hover:text-white transition-all duration-300">
          <div class="p-2 rounded-xl group-hover:bg-white/10 transition-all duration-300">
            <MapPin class="w-6 h-6" />
          </div>
          <span class="text-xs mt-1 font-medium">Maps</span>
        </a>
        <a href="#gallery" class="nav-icon-link group flex flex-col items-center justify-center text-white/70 hover:text-white transition-all duration-300">
          <div class="p-2 rounded-xl group-hover:bg-white/10 transition-all duration-300">
            <Image class="w-6 h-6" />
          </div>
          <span class="text-xs mt-1 font-medium">Gallery</span>
        </a>
        <a href="#gift" class="nav-icon-link group flex flex-col items-center justify-center text-white/70 hover:text-white transition-all duration-300">
          <div class="p-2 rounded-xl group-hover:bg-white/10 transition-all duration-300">
            <Gift class="w-6 h-6" />
          </div>
          <span class="text-xs mt-1 font-medium">Gift</span>
        </a>
        <a href="#rsvp" class="nav-icon-link group flex flex-col items-center justify-center text-white/70 hover:text-white transition-all duration-300">
          <div class="p-2 rounded-xl group-hover:bg-white/10 transition-all duration-300">
            <MessageCircle class="w-6 h-6" />
          </div>
          <span class="text-xs mt-1 font-medium">RSVP</span>
        </a>
      </div>
    </div>
  </nav>

  <!-- Hero Section -->
  <section id="hero" class="relative min-h-screen flex items-center justify-center overflow-hidden gradient-bg">
    <!-- Animated Background Shapes -->
    <div class="absolute inset-0 overflow-hidden">
      <div class="floating-shape shape-1"></div>
      <div class="floating-shape shape-2"></div>
      <div class="floating-shape shape-3"></div>
    </div>

    <div class="relative z-10 text-center px-4 max-w-4xl mx-auto animate-fade-in">
      <div class="mb-8">
        <span class="inline-block px-6 py-2 rounded-full glass-effect text-white text-sm font-medium mb-6">
          {event.cover.title}
        </span>
      </div>

      <h1 class="text-6xl md:text-8xl font-bold mb-6 text-white leading-tight">
        {event.cover.bride}
        <span class="text-accent-400">&</span>
        {event.cover.groom}
      </h1>

      <p class="text-xl md:text-2xl text-white/90 mb-12 font-light">
        {formattedDate}
      </p>

      <!-- Countdown -->
      <div id="countdown" class="flex justify-center gap-3 mb-12 flex-wrap">
        <div class="glass-effect rounded-lg p-5 min-w-[85px] hover:scale-105 transition-transform duration-300">
          <div id="days" class="text-4xl font-bold text-white mb-1">00</div>
          <div class="text-xs uppercase tracking-wider text-white/70">Days</div>
        </div>
        <div class="glass-effect rounded-lg p-5 min-w-[85px] hover:scale-105 transition-transform duration-300">
          <div id="hours" class="text-4xl font-bold text-white mb-1">00</div>
          <div class="text-xs uppercase tracking-wider text-white/70">Hours</div>
        </div>
        <div class="glass-effect rounded-lg p-5 min-w-[85px] hover:scale-105 transition-transform duration-300">
          <div id="minutes" class="text-4xl font-bold text-white mb-1">00</div>
          <div class="text-xs uppercase tracking-wider text-white/70">Minutes</div>
        </div>
        <div class="glass-effect rounded-lg p-5 min-w-[85px] hover:scale-105 transition-transform duration-300">
          <div id="seconds" class="text-4xl font-bold text-white mb-1">00</div>
          <div class="text-xs uppercase tracking-wider text-white/70">Seconds</div>
        </div>
      </div>

      <div class="glass-effect rounded-lg p-6 max-w-md mx-auto mb-8">
        <p class="text-sm text-white/70 mb-2">Dear</p>
        <p class="text-2xl font-bold text-white">{guestName}</p>
      </div>

      <a 
        href="#couple" 
        class="inline-flex items-center gap-2 bg-white text-slate-900 px-8 py-3.5 rounded-lg font-semibold hover:bg-white/90 transition-all duration-300 shadow-lg hover:shadow-xl"
      >
        Open Invitation
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3"/>
        </svg>
      </a>
    </div>
  </section>

  <!-- Couple Section -->
  <section id="couple" class="py-24 bg-gradient-to-b from-slate-50 to-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-20 animate-fade-in-up">
        <h2 class="text-5xl md:text-6xl font-bold text-slate-900 mb-4">The Couple</h2>
        <div class="w-24 h-1.5 bg-gradient-to-r from-accent-400 to-accent-600 mx-auto rounded-full"></div>
      </div>

      <div class="grid md:grid-cols-2 gap-16 max-w-6xl mx-auto mb-20">
        <!-- Bride -->
        <div class="text-center group animate-fade-in-up" style="animation-delay: 0.1s">
          <div class="relative inline-block mb-8">
            <div class="absolute inset-0 bg-gradient-to-br from-accent-400 to-accent-600 rounded-xl blur-xl opacity-20 group-hover:opacity-30 transition-opacity duration-500"></div>
            <div class="relative w-80 h-80 rounded-xl overflow-hidden shadow-xl mx-auto border-2 border-white/50 group-hover:scale-105 transition-transform duration-500">
              <img src={event.couple.bride.photo_url} alt={event.couple.bride.full_name} class="w-full h-full object-cover">
            </div>
          </div>
          <h3 class="text-3xl font-bold text-slate-900 mb-2">{event.couple.bride.full_name}</h3>
          <p class="text-slate-600 mb-4">{event.couple.bride.parents}</p>
          <a href={`https://instagram.com/${event.couple.bride.instagram.replace('@', '')}`} target="_blank" class="inline-flex items-center gap-2 text-accent-600 hover:text-accent-700 font-medium">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
            {event.couple.bride.instagram}
          </a>
        </div>

        <!-- Groom -->
        <div class="text-center group animate-fade-in-up" style="animation-delay: 0.2s">
          <div class="relative inline-block mb-8">
            <div class="absolute inset-0 bg-gradient-to-br from-accent-400 to-accent-600 rounded-xl blur-xl opacity-20 group-hover:opacity-30 transition-opacity duration-500"></div>
            <div class="relative w-80 h-80 rounded-xl overflow-hidden shadow-xl mx-auto border-2 border-white/50 group-hover:scale-105 transition-transform duration-500">
              <img src={event.couple.groom.photo_url} alt={event.couple.groom.full_name} class="w-full h-full object-cover">
            </div>
          </div>
          <h3 class="text-3xl font-bold text-slate-900 mb-2">{event.couple.groom.full_name}</h3>
          <p class="text-slate-600 mb-4">{event.couple.groom.parents}</p>
          <a href={`https://instagram.com/${event.couple.groom.instagram.replace('@', '')}`} target="_blank" class="inline-flex items-center gap-2 text-accent-600 hover:text-accent-700 font-medium">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
              <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
            </svg>
            {event.couple.groom.instagram}
          </a>
        </div>
      </div>

      <!-- Love Story -->
      <div class="max-w-3xl mx-auto text-center animate-fade-in-up" style="animation-delay: 0.3s">
        <div class="glass-effect-light rounded-xl p-10 shadow-lg">
          <div class="w-14 h-14 bg-gradient-to-br from-accent-400 to-accent-600 rounded-lg flex items-center justify-center mx-auto mb-6">
            <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M3.172 5.172a4 4 0 015.656 0L10 6.343l1.172-1.171a4 4 0 115.656 5.656L10 17.657l-6.828-6.829a4 4 0 010-5.656z" clip-rule="evenodd"/>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-slate-900 mb-6">Our Story</h3>
          <p class="text-slate-600 leading-relaxed text-lg">{event.couple.story}</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Event Details Section -->
  <section id="event" class="py-24 gradient-bg-light">
    <div class="container mx-auto px-4">
      <div class="text-center mb-20 animate-fade-in-up">
        <h2 class="text-5xl md:text-6xl font-bold text-slate-900 mb-4">Event Details</h2>
        <div class="w-24 h-1.5 bg-gradient-to-r from-accent-400 to-accent-600 mx-auto rounded-full"></div>
      </div>

      <div class="grid md:grid-cols-2 gap-8 max-w-5xl mx-auto">
        {event.events.map((evt, index) => (
          <div class="glass-effect-light rounded-xl p-8 text-center hover:scale-105 transition-all duration-500 shadow-lg animate-fade-in-up" style={`animation-delay: ${index * 0.1}s`}>
            <div class="w-16 h-16 bg-gradient-to-br from-accent-400 to-accent-600 rounded-lg flex items-center justify-center mx-auto mb-6">
              <svg class="w-10 h-10 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
              </svg>
            </div>
            <h3 class="text-3xl font-bold text-slate-900 mb-6">{evt.type}</h3>
            <div class="space-y-4 text-slate-600">
              <p class="flex items-center justify-center gap-3 text-lg">
                <svg class="w-5 h-5 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                </svg>
                {new Date(evt.date).toLocaleDateString('id-ID', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' })}
              </p>
              <p class="flex items-center justify-center gap-3 text-lg">
                <svg class="w-5 h-5 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
                </svg>
                {evt.time}
              </p>
              <p class="flex items-center justify-center gap-3 text-lg font-semibold text-slate-900">
                <svg class="w-5 h-5 text-accent-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
                </svg>
                {evt.location}
              </p>
              <p class="text-sm text-slate-500">{evt.address}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Maps Section -->
  <section id="maps" class="py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-16 animate-fade-in-up">
        <h2 class="text-5xl md:text-6xl font-bold text-slate-900 mb-4">Location</h2>
        <div class="w-24 h-1.5 bg-gradient-to-r from-accent-400 to-accent-600 mx-auto rounded-full mb-6"></div>
        <p class="text-slate-600 text-lg max-w-2xl mx-auto">{event.location.address}</p>
      </div>

      <div class="max-w-5xl mx-auto">
        <div class="rounded-xl overflow-hidden shadow-xl">
          <iframe 
            src={event.location.maps_embed}
            width="100%" 
            height="500" 
            style="border:0;" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="no-referrer-when-downgrade"
            class="w-full"
          ></iframe>
          <div class="bg-gradient-to-br from-slate-50 to-white p-8 text-center">
            <a 
              href={event.location.maps_url} 
              target="_blank"
              class="inline-flex items-center gap-2 bg-accent-600 hover:bg-accent-700 text-white px-8 py-3.5 rounded-lg font-semibold transition-all duration-300 shadow-md hover:shadow-lg"
            >
              <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              Open in Google Maps
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Gallery Section -->
  <section id="gallery" class="py-24 gradient-bg-light">
    <div class="container mx-auto px-4">
      <div class="text-center mb-20 animate-fade-in-up">
        <h2 class="text-5xl md:text-6xl font-bold text-slate-900 mb-4">Gallery</h2>
        <div class="w-24 h-1.5 bg-gradient-to-r from-accent-400 to-accent-600 mx-auto rounded-full"></div>
      </div>

      <div class="grid grid-cols-2 md:grid-cols-3 gap-6 max-w-6xl mx-auto">
        {event.gallery.map((photo, index) => (
          <div class="relative overflow-hidden rounded-lg shadow-lg group animate-fade-in-up hover:scale-105 transition-all duration-500" style={`animation-delay: ${index * 0.05}s`}>
            <img 
              src={photo.url} 
              alt={photo.caption}
              class="w-full h-72 object-cover"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-slate-900/90 via-slate-900/50 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-end justify-center p-6">
              <p class="text-white text-center font-medium">{photo.caption}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- RSVP Section -->
  <section id="rsvp" class="py-24 bg-white">
    <div class="container mx-auto px-4">
      <div class="text-center mb-16 animate-fade-in-up">
        <h2 class="text-5xl md:text-6xl font-bold text-slate-900 mb-4">RSVP</h2>
        <div class="w-24 h-1.5 bg-gradient-to-r from-accent-400 to-accent-600 mx-auto rounded-full mb-6"></div>
        <p class="text-slate-600 text-lg max-w-2xl mx-auto">Please confirm your attendance</p>
      </div>

      <div class="max-w-2xl mx-auto glass-effect-light rounded-xl p-8 shadow-lg">
        <form id="rsvp-form" class="space-y-6">
          <div>
            <label class="block text-sm font-semibold text-slate-700 mb-3">Name</label>
            <input 
              type="text" 
              name="name" 
              value={guestName}
              readonly
              class="w-full px-5 py-3.5 border border-slate-300 rounded-lg bg-white font-medium text-slate-900 focus:outline-none focus:border-accent-400 transition-colors"
            />
          </div>

          <div>
            <label class="block text-sm font-semibold text-slate-700 mb-3">Attendance Confirmation</label>
            <div class="grid grid-cols-3 gap-4">
              <label class="relative cursor-pointer">
                <input type="radio" name="status" value="hadir" class="sr-only peer" required />
                <div class="p-5 border border-slate-300 rounded-lg text-center hover:border-accent-400 peer-checked:border-accent-500 peer-checked:bg-accent-50 transition-all duration-300">
                  <svg class="w-8 h-8 mx-auto mb-2 text-slate-400 peer-checked:text-accent-600" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
                  </svg>
                  <span class="text-sm font-semibold text-slate-700">Attending</span>
                </div>
              </label>

              <label class="relative cursor-pointer">
                <input type="radio" name="status" value="tidak_hadir" class="sr-only peer" />
                <div class="p-5 border border-slate-300 rounded-lg text-center hover:border-accent-400 peer-checked:border-accent-500 peer-checked:bg-accent-50 transition-all duration-300">
                  <svg class="w-8 h-8 mx-auto mb-2 text-slate-400 peer-checked:text-accent-600" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
                  </svg>
                  <span class="text-sm font-semibold text-slate-700">Not Attending</span>
                </div>
              </label>

              <label class="relative cursor-pointer">
                <input type="radio" name="status" value="ragu" class="sr-only peer" />
                <div class="p-5 border border-slate-300 rounded-lg text-center hover:border-accent-400 peer-checked:border-accent-500 peer-checked:bg-accent-50 transition-all duration-300">
                  <svg class="w-8 h-8 mx-auto mb-2 text-slate-400 peer-checked:text-accent-600" fill="currentColor" viewBox="0 0 20 20">
                    <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-8-3a1 1 0 00-.867.5 1 1 0 11-1.731-1A3 3 0 0113 8a3.001 3.001 0 01-2 2.83V11a1 1 0 11-2 0v-1a1 1 0 011-1 1 1 0 100-2zm0 8a1 1 0 100-2 1 1 0 000 2z" clip-rule="evenodd"/>
                  </svg>
                  <span class="text-sm font-semibold text-slate-700">Maybe</span>
                </div>
              </label>
            </div>
          </div>

          <div>
            <label class="block text-sm font-semibold text-slate-700 mb-3">Message & Wishes (Optional)</label>
            <textarea 
              name="message" 
              rows="4" 
              class="w-full px-5 py-3.5 border border-slate-300 rounded-lg focus:border-accent-400 focus:outline-none transition-colors resize-none"
              placeholder="Write your message and wishes for us..."
            ></textarea>
          </div>

          <button 
            type="submit" 
            class="w-full bg-accent-600 hover:bg-accent-700 text-white py-3.5 rounded-lg font-semibold transition-all duration-300 shadow-md hover:shadow-lg"
          >
            Send Confirmation
          </button>

          <div id="rsvp-message" class="hidden p-4 rounded-lg"></div>
        </form>
      </div>
    </div>
  </section>

  <!-- Gift Section -->
  <section id="gift" class="py-24 gradient-bg-light">
    <div class="container mx-auto px-4">
      <div class="text-center mb-16 animate-fade-in-up">
        <h2 class="text-5xl md:text-6xl font-bold text-slate-900 mb-4">Wedding Gift</h2>
        <div class="w-24 h-1.5 bg-gradient-to-r from-accent-400 to-accent-600 mx-auto rounded-full mb-6"></div>
        <p class="text-slate-600 text-lg max-w-2xl mx-auto">{event.gift.message}</p>
      </div>

      <div class="max-w-3xl mx-auto grid md:grid-cols-2 gap-6">
        {event.gift.accounts.map((account, index) => (
          <div class="glass-effect-light rounded-xl p-6 hover:scale-105 transition-all duration-500 shadow-lg animate-fade-in-up" style={`animation-delay: ${index * 0.1}s`}>
            <div class="w-14 h-14 bg-gradient-to-br from-accent-400 to-accent-600 rounded-lg flex items-center justify-center mx-auto mb-5">
              <svg class="w-8 h-8 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z"/>
              </svg>
            </div>
            <h3 class="text-2xl font-bold text-slate-900 text-center mb-3">{account.bank}</h3>
            <p class="text-3xl font-mono font-bold text-accent-600 text-center mb-2">{account.account_number}</p>
            <p class="text-sm text-slate-600 text-center mb-6">{account.account_name}</p>
            <button 
              onclick={`navigator.clipboard.writeText('${account.account_number}'); this.textContent='Copied!'; setTimeout(() => this.textContent='Copy Account Number', 2000)`}
              class="w-full bg-accent-600 hover:bg-accent-700 text-white py-3 rounded-lg font-semibold transition-all duration-300 shadow-md hover:shadow-lg"
            >
              Copy Account Number
            </button>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Footer -->
  <footer class="bg-slate-900 text-white py-16">
    <div class="container mx-auto px-4 text-center">
      <p class="text-3xl font-bold mb-3">Thank You</p>
      <p class="text-slate-400 text-lg mb-8">{event.cover.bride} & {event.cover.groom}</p>
      <div class="w-24 h-1.5 bg-gradient-to-r from-accent-400 to-accent-600 mx-auto rounded-full mb-8"></div>
      <p class="text-sm text-slate-500">Made with ❤️ by Undangan Digital Platform</p>
    </div>
  </footer>

  <style>
    /* Gradient Backgrounds */
    .gradient-bg {
      background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
    }

    .gradient-bg-light {
      background: linear-gradient(135deg, #f5f7fa 0%, #c3cfe2 100%);
    }

    /* Glassmorphism Effects */
    .glass-effect {
      background: rgba(255, 255, 255, 0.15);
      backdrop-filter: blur(12px);
      border: 1px solid rgba(255, 255, 255, 0.25);
    }

    .glass-effect-nav {
      background: rgba(15, 23, 42, 0.85);
      backdrop-filter: blur(16px);
    }

    .glass-effect-light {
      background: rgba(255, 255, 255, 0.8);
      backdrop-filter: blur(8px);
      border: 1px solid rgba(255, 255, 255, 0.4);
    }

    /* Floating Shapes Animation */
    .floating-shape {
      position: absolute;
      border-radius: 50%;
      background: rgba(255, 255, 255, 0.1);
      animation: float 20s infinite ease-in-out;
    }

    .shape-1 {
      width: 300px;
      height: 300px;
      top: 10%;
      left: 10%;
      animation-delay: 0s;
    }

    .shape-2 {
      width: 200px;
      height: 200px;
      top: 60%;
      right: 15%;
      animation-delay: 5s;
    }

    .shape-3 {
      width: 150px;
      height: 150px;
      bottom: 20%;
      left: 20%;
      animation-delay: 10s;
    }

    @keyframes float {
      0%, 100% {
        transform: translateY(0) rotate(0deg);
      }
      50% {
        transform: translateY(-50px) rotate(180deg);
      }
    }

    /* Fade In Animations */
    @keyframes fade-in {
      from {
        opacity: 0;
      }
      to {
        opacity: 1;
      }
    }

    @keyframes fade-in-up {
      from {
        opacity: 0;
        transform: translateY(30px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }

    .animate-fade-in {
      animation: fade-in 1s ease-out;
    }

    .animate-fade-in-up {
      animation: fade-in-up 0.8s ease-out;
      animation-fill-mode: both;
    }

    /* Smooth Scroll */
    html {
      scroll-behavior: smooth;
    }

    /* Active Nav Link */
    .nav-icon-link.active {
      color: white;
    }

    .nav-icon-link.active div {
      background: rgba(255, 255, 255, 0.2);
    }
  </style>

  <script define:vars={{ eventDate: event.cover.date }}>
    // Countdown Timer
    function updateCountdown() {
      const target = new Date(eventDate).getTime();
      const now = new Date().getTime();
      const diff = target - now;

      if (diff > 0) {
        const days = Math.floor(diff / (1000 * 60 * 60 * 24));
        const hours = Math.floor((diff % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
        const minutes = Math.floor((diff % (1000 * 60 * 60)) / (1000 * 60));
        const seconds = Math.floor((diff % (1000 * 60)) / 1000);

        document.getElementById('days').textContent = String(days).padStart(2, '0');
        document.getElementById('hours').textContent = String(hours).padStart(2, '0');
        document.getElementById('minutes').textContent = String(minutes).padStart(2, '0');
        document.getElementById('seconds').textContent = String(seconds).padStart(2, '0');
      }
    }

    updateCountdown();
    setInterval(updateCountdown, 1000);

    // Music Player
    const audio = document.getElementById('background-music');
    const toggleBtn = document.getElementById('music-toggle');
    const playIcon = document.getElementById('music-icon-play');
    const pauseIcon = document.getElementById('music-icon-pause');

    toggleBtn.addEventListener('click', () => {
      if (audio.paused) {
        audio.play();
        playIcon.classList.add('hidden');
        pauseIcon.classList.remove('hidden');
      } else {
        audio.pause();
        playIcon.classList.remove('hidden');
        pauseIcon.classList.add('hidden');
      }
    });

    // Active Nav Link on Scroll
    const sections = document.querySelectorAll('section[id]');
    const navLinks = document.querySelectorAll('.nav-icon-link');

    window.addEventListener('scroll', () => {
      let current = '';
      sections.forEach(section => {
        const sectionTop = section.offsetTop;
        const sectionHeight = section.clientHeight;
        if (pageYOffset >= sectionTop - 200) {
          current = section.getAttribute('id');
        }
      });

      navLinks.forEach(link => {
        link.classList.remove('active');
        if (link.getAttribute('href') === `#${current}`) {
          link.classList.add('active');
        }
      });
    });

    // RSVP Form
    const rsvpForm = document.getElementById('rsvp-form');
    const rsvpMessage = document.getElementById('rsvp-message');

    rsvpForm.addEventListener('submit', async (e) => {
      e.preventDefault();
      
      const formData = new FormData(rsvpForm);
      const data = {
        name: formData.get('name'),
        status: formData.get('status'),
        message: formData.get('message')
      };

      console.log('RSVP Data:', data);
      
      rsvpMessage.classList.remove('hidden', 'bg-red-100', 'text-red-700');
      rsvpMessage.classList.add('bg-green-100', 'text-green-700');
      rsvpMessage.textContent = 'Thank you! Your confirmation has been received.';
      
      setTimeout(() => {
        rsvpMessage.classList.add('hidden');
      }, 5000);
    });
  </script>
</BaseLayout>
